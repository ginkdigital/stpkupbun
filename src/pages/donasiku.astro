---
import BaseLayout from '../layouts/BaseLayout.astro';

// JSON-LD Schema Data
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      "name": "STP Khoiru Ummah Pangkalan Bun",
      "alternateName": "Sekolah Islam Tahfizh Plus Khoiru Ummah Pangkalan Bun",
      "url": "https://stpkupbun.pages.dev",
      "description": "Sekolah tahfidz terpadu TK hingga SMA di Pangkalan Bun, Kotawaringin Barat, Kalimantan Tengah. Bagian dari jaringan 80 sekolah Khoiru Ummah di 16 provinsi Indonesia.",
      "foundingDate": "2013",
      "legalName": "Yayasan Khoiru Ummah Pembangun Peradaban",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. Samari 2, GG. Barokah RT.25, Kel. Madurejo",
        "addressLocality": "Pangkalan Bun",
        "addressRegion": "Kotawaringin Barat",
        "addressCountry": "ID",
        "postalCode": "74112"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-2.6833",
        "longitude": "111.6167"
      },
      "areaServed": { "@type": "City", "name": "Pangkalan Bun" },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Admissions",
        "url": "https://klikaja.app/tanyakupbun",
        "availableLanguage": "Indonesian"
      },
      "sameAs": [
        "https://khoiruummah.id",
        "https://linktr.ee/stpkupbun",
        "https://instagram.com/khoiruummahpbun_sd"
      ]
    },
    {
      "@type": "DonateAction",
      "name": "DonasiKU — 3 Pintu Amal Jariyah STPKU Pangkalan Bun",
      "description": "Program donasi resmi STP Khoiru Ummah Pangkalan Bun dengan 3 pintu amal jariyah untuk program IQC dan HIT.",
      "url": "https://stpkupbun.pages.dev/donasiku",
      "recipient": {
        "@type": "EducationalOrganization",
        "name": "STP Khoiru Ummah Pangkalan Bun"
      },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "7500000",
        "priceCurrency": "IDR",
        "description": "Biaya per peserta program IQC dan HIT"
      }
    }
  ]
};

// Data
const institution = {
  name: 'STP Khoiru Ummah Pangkalan Bun',
  target: 195000000,
  targetFormatted: 'Rp 195 Jt',
  iqcCollected: 64350000,
  iqcPercent: 33,
  iqcRemaining: '±Rp 130 Jt',
  perParticipant: 7500000,
  participants: 15,
  bank: 'Bank Syariah Indonesia (BSI)',
  accountNumber: '7148055488',
  accountName: 'Megawati Apriani',
  waLink: 'https://wa.me/6281234567890?text=Assalamu%27alaikum.%20Saya%20ingin%20berpartisipasi%20dalam%20DonasiKU%20STPKU%20Pangkalan%20Bun%20untuk%20program%20IQC%20%26%20HIT.',
  waText: '💬 Konfirmasi Donasi via WhatsApp',
  stats: {
    tahun: '8',
    tahunLabel: 'Tahun Berdiri di Kalteng',
    santri: '51',
    jalurSantri: 'Santri Aktif (TK–SMP)',
    asatidz: '11',
    asatidzLabel: 'Asatidz/ah Berdedikasi',
  },
  programs: [
    {
      name: 'IQC',
      full: 'Islamic Quiz Competition',
      icon: '🏆',
      desc: 'Kompetisi bergengsi tingkat nasional yang menguji kecerdasan, hafalan, dan wawasan Islam santo terbaik STPKU. Kesempatan langka yang membuktikan: santo Kalimantan tidak kalah dengan santo kota besar manapun.',
      biaya: 'Rp 7.500.000',
    },
    {
      name: 'HIT',
      full: 'Halaqah Intensive Training',
      icon: '📖',
      desc: 'Program pelatihan intensif yang membekali santo dengan ilmu dan pengalaman yang tidak bisa mereka dapatkan dari buku teks. Investasi terbaik untuk generasi Syakhshiyah Islamiyah terpilih.',
      biaya: 'Rp 7.500.000',
    }
  ],
  tiers: [
    {
      badge: 'Paling Berdampak',
      featured: true,
      number: '⭐',
      amount: 'Rp 7.500.000',
      label: 'Sponsor Penuh — 1 Peserta',
      desc: 'Tanggung seluruh biaya satu santo menuju IQC atau HIT. Satu nama Anda, satu santo berangkat, satu perjalanan menuju prestasi atas nama Allah.'
    },
    {
      badge: '',
      featured: false,
      number: '2',
      amount: 'Rp 500.000 – Rp 5.000.000',
      label: 'Sponsor Parsial',
      desc: 'Bergabung dengan donatur lain dalam pool dana kolektif. Setiap kontribusi dicatat dan diperhitungkan. Dana digabungkan untuk memberangkatkan peserta bersama-sama.'
    },
    {
      badge: '',
      featured: false,
      number: '3',
      amount: 'Donasi Bebas',
      label: 'Berapapun yang Allah Lapangkan',
      desc: 'Tidak ada minimum. Rp 50.000 adalah Sedekah Jariyah yang sama mulianya. Yang penting niatnya bersih dan transfernya nyata.'
    }
  ]
};
---

<BaseLayout
  title="DonasiKU — STPKU Pangkalan Bun | IQC & HIT 2026"
  description="51 santo penghafal Al-Qur'an di Kalimantan Tengah siap berlomba. Bantu mereka berangkat melalui Sedekah Jariyah Anda."
>
  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO SECTION -->
  <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_0%,_rgba(26,107,74,0.08)_0%,_transparent_70%)] pointer-events-none"></div>

    <p class="font-serif text-xl md:text-2xl text-gold-500 tracking-widest mb-6 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
      بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيْمِ
    </p>

    <div class="inline-flex items-center gap-2 bg-emerald-100 border border-emerald-600/10 text-emerald-600 text-xs font-semibold uppercase tracking-wider px-4 py-1.5 rounded-full mb-7 opacity-0 animate-fade-up" style="animation-delay: 0.2s;">
      🕋 Program IQC & HIT 2026 — Khoiru Ummah Pangkalan Bun
    </div>

    <h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold leading-tight mb-3 text-ink opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
      <span class="text-emerald-600">51 Santo</span> Penghafal<br>
      Al-Qur'an di Kalimantan<br>
      Menunggu Tangan Anda
    </h1>

    <p class="text-base md:text-lg text-ink-muted max-w-xl mx-auto mb-10 leading-relaxed opacity-0 animate-fade-up" style="animation-delay: 0.4s;">
      Mereka sudah hafal. Mereka sudah siap berlomba.<br>
      Yang belum tersedia hanya satu:<br>
      <strong class="text-emerald-600 font-bold">dana untuk memberangkatkan mereka.</strong>
    </p>

    <div class="flex flex-col sm:flex-row border border-emerald-600/10 rounded-xl overflow-hidden mb-10 opacity-0 animate-fade-up" style="animation-delay: 0.5s;">
      <div class="flex-1 bg-white px-5 py-4 text-center">
        <span class="block text-xl md:text-2xl font-extrabold text-emerald-600">{institution.targetFormatted}</span>
        <span class="text-xs text-ink-faint font-semibold uppercase tracking-wide">Target Dana</span>
      </div>
      <div class="flex-1 bg-white px-5 py-4 text-center border-t sm:border-t-0 sm:border-l border-emerald-600/10">
        <span class="block text-xl md:text-2xl font-extrabold text-gold-500">{institution.iqcPercent}%</span>
        <span class="text-xs text-ink-faint font-semibold uppercase tracking-wide">IQC Terkumpul</span>
      </div>
      <div class="flex-1 bg-white px-5 py-4 text-center border-t sm:border-t-0 sm:border-l border-emerald-600/10 rounded-b-xl sm:rounded-b-none">
        <span class="block text-xl md:text-2xl font-extrabold text-red-progress">{institution.iqcRemaining}</span>
        <span class="text-xs text-ink-faint font-semibold uppercase tracking-wide">Masih Kurang</span>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 justify-center opacity-0 animate-fade-up" style="animation-delay: 0.6s;">
      <a href="#donasi" class="inline-flex items-center gap-2 bg-emerald-600 text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-emerald-600/30 hover:bg-emerald-500 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-emerald-600/40 transition-all duration-300">
        💚 Saya Ingin Berpartisipasi
      </a>
      <a href="#lembaga" class="bg-white text-emerald-600 border-2 border-emerald-600/10 font-semibold px-7 py-4 rounded-xl hover:border-emerald-600 hover:bg-emerald-100 transition-all duration-300">
        Kenali Dulu Mereka
      </a>
    </div>
  </section>

  <!-- LEMBAGA SECTION -->
  <section id="lembaga" class="bg-white border-y border-emerald-600/10 py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="reveal">
        <span class="inline-block bg-gold-100 border border-gold-500/30 text-gold-500 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Siapa Mereka?
        </span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-ink mb-4 leading-tight">
          SD Tahfizh Plus Khoiru Ummah<br>Pangkalan Bun
        </h2>
        <p class="text-ink-muted leading-relaxed">
          Bagian dari jaringan sekolah tahfizh nasional Khoiru Ummah — hadir di Kotawaringin Barat, Kalimantan Tengah sejak 2018. Bukan sekolah biasa. Di sini, santo aktif dari jenjang TK hingga SMP dibentuk karakternya, dibangun akidahnya, dan dilatih menghafalkan kalam Allah — oleh para asatidz/ah yang berdedikasi penuh.
        </p>
      </div>

      <div class="reveal grid grid-cols-1 md:grid-cols-3 gap-px bg-emerald-600/10 border border-emerald-600/10 rounded-2xl overflow-hidden my-9">
        <div class="bg-emerald-100 py-7 px-5 text-center">
          <span class="block font-serif text-4xl font-bold text-emerald-600">{institution.stats.tahun}</span>
          <span class="text-sm text-emerald-500 font-medium mt-1 block">{institution.stats.tahunLabel}</span>
        </div>
        <div class="bg-emerald-100 py-7 px-5 text-center">
          <span class="block font-serif text-4xl font-bold text-emerald-600">{institution.stats.santri}</span>
          <span class="text-sm text-emerald-500 font-medium mt-1 block">{institution.stats.jalurSantri}</span>
        </div>
        <div class="bg-emerald-100 py-7 px-5 text-center">
          <span class="block font-serif text-4xl font-bold text-emerald-600">{institution.stats.asatidz}</span>
          <span class="text-sm text-emerald-500 font-medium mt-1 block">{institution.stats.asatidzLabel}</span>
        </div>
      </div>

      <div class="reveal text-sm text-ink-muted leading-relaxed mb-2">
        Di bawah kepemimpinan <strong class="text-ink">Ustadz Mukhlis Syuaib, S.Pd</strong>, STPKU Pangkalan Bun telah delapan tahun mencetak generasi Syakhshiyah Islamiyah — santo yang berpikir dengan aqidah, bukan sekadar mengejar nilai akademik.
      </div>

      <div class="reveal text-sm text-ink-muted mb-8">
        <strong class="block text-ink mb-2 text-sm">Para Pengajar Aktif:</strong>
        Mukhlis Syuaib S.Pd, Dewi Lestari, Endah Retno Megawati S.Pt, Mutia Fauziah S.Pd, Egha Sefyatus Solichah, Fauziah Puji Lestari S.Ak, Naimah, Irma Agustin F. S.Pd, Megawati Apriani, Kholisaton Hamdanah, Nia Kurniati Hasibuan S.H.I M.H.
      </div>

      <div class="reveal bg-emerald-600 text-white p-7 rounded-2xl relative overflow-hidden">
        <span class="absolute -top-4 left-4 text-8xl text-white/10 font-serif leading-none">❝</span>
        <p class="font-serif text-lg leading-relaxed text-white/90 relative z-10">
          "Barangsiapa yang menempuh suatu jalan untuk mencari ilmu, maka Allah akan memudahkan baginya jalan menuju surga."
        </p>
        <cite class="block text-xs text-gold-300 font-semibold mt-3 tracking-wide not-italic relative z-10">
          — HR. Muslim | Fondasi filosofi STPKU Pangkalan Bun
        </cite>
      </div>
    </div>
  </section>

  <!-- PROGRAM SECTION -->
  <section id="program" class="py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="reveal">
        <span class="inline-block bg-gold-100 border border-gold-500/30 text-gold-500 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Program Unggulan
        </span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-ink mb-4 leading-tight">
          Dua Program yang<br>Membutuhkan Dukungan Anda
        </h2>
        <p class="text-ink-muted leading-relaxed">
          Dana yang terkumpul akan digunakan untuk memberangkatkan <strong class="text-ink">{institution.participants} peserta terpilih</strong> dari STPKU Pangkalan Bun mengikuti dua program bergengsi Khoiru Ummah secara nasional.
        </p>
      </div>

      <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-4 my-9">
        {institution.programs.map((program) => (
          <div class="bg-white border border-emerald-600/10 rounded-2xl p-7 relative overflow-hidden hover:-translate-y-1 hover:shadow-xl hover:shadow-emerald-600/10 transition-all duration-300">
            <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-600 to-gold-500"></div>
            <span class="text-4xl mb-3 block">{program.icon}</span>
            <div class="text-lg font-extrabold text-emerald-600 mb-1">{program.name}</div>
            <span class="text-xs text-ink-faint font-semibold uppercase tracking-wide block mb-3">{program.full}</span>
            <p class="text-sm text-ink-muted leading-relaxed">{program.desc}</p>
            <div class="mt-5 pt-4 border-t border-emerald-600/10 text-sm text-ink-muted">
              Biaya per peserta:
              <strong class="text-xl text-emerald-600 font-extrabold block">{program.biaya}</strong>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal text-center text-gold-500 text-2xl tracking-[2rem] opacity-40 my-12">
        ✦ ✦ ✦
      </div>
    </div>
  </section>

  <!-- PROGRESS SECTION -->
  <section class="bg-ink text-white py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="reveal">
        <span class="inline-block bg-gold-500/10 border border-gold-500/20 text-gold-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Status Dana Real-Time
        </span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">
          Berapa yang Sudah<br>Terkumpul?
        </h2>
        <p class="text-white/60 leading-relaxed">
          Angka-angka ini adalah fakta. Bukan bujukan. Anda berhak tahu persis di mana posisi kita sekarang.
        </p>
      </div>

      <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-5 my-9">
        <!-- IQC Progress -->
        <div class="progress-card bg-white/5 border border-white/10 rounded-2xl p-7">
          <div class="flex justify-between items-start mb-5 flex-wrap gap-2">
            <div>
              <div class="font-bold text-lg text-white">🏆 Program IQC</div>
              <div class="text-xs text-white/40 mt-1">Islamic Quiz Competition</div>
            </div>
            <div class="font-serif text-4xl font-bold text-gold-500 leading-none">{institution.iqcPercent}%</div>
          </div>
          <div class="bg-white/10 rounded-full h-3 overflow-hidden mb-4">
            <div class="progress-bar-fill h-full rounded-full bg-gradient-to-r from-emerald-500 to-gold-500" style={`width: ${institution.iqcPercent}%`}></div>
          </div>
          <div class="flex justify-between flex-wrap gap-2">
            <div class="text-center">
              <span class="block text-lg font-extrabold text-green-400">Rp 64.350.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Terkumpul</span>
            </div>
            <div class="text-center">
              <span class="block text-lg font-extrabold text-white">Rp 195.000.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Total Target</span>
            </div>
            <div class="text-center">
              <span class="block text-lg font-extrabold text-red-400">Rp 130.650.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Masih Kurang</span>
            </div>
          </div>
        </div>

        <!-- HIT Progress -->
        <div class="progress-card bg-white/5 border border-white/10 rounded-2xl p-7">
          <div class="flex justify-between items-start mb-5 flex-wrap gap-2">
            <div>
              <div class="font-bold text-lg text-white">📖 Program HIT</div>
              <div class="text-xs text-white/40 mt-1">Per peserta (dari {institution.participants} orang)</div>
            </div>
            <div class="font-serif text-4xl font-bold text-gold-500 leading-none">25%</div>
          </div>
          <div class="bg-white/10 rounded-full h-3 overflow-hidden mb-4">
            <div class="progress-bar-fill h-full rounded-full bg-gradient-to-r from-emerald-500 to-gold-500" style="width: 25%"></div>
          </div>
          <div class="flex justify-between flex-wrap gap-2">
            <div class="text-center">
              <span class="block text-lg font-extrabold text-green-400">Rp 1.875.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Terkumpul/orang</span>
            </div>
            <div class="text-center">
              <span class="block text-lg font-extrabold text-white">Rp 7.500.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Target/peserta</span>
            </div>
            <div class="text-center">
              <span class="block text-lg font-extrabold text-red-400">Rp 5.625.000</span>
              <span class="text-xs text-white/40 uppercase tracking-wide">Kurang/peserta</span>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal bg-gold-500/10 border border-gold-500/20 rounded-xl p-4 text-sm text-white/70 leading-relaxed">
        <strong class="text-gold-300 block mb-1">📋 {institution.participants} peserta × Rp 7.500.000 = Rp 112.500.000</strong>
        yang harus terpenuhi agar seluruh peserta terpilih bisa berangkat tanpa satu pun yang tertinggal karena alasan biaya.
      </div>
    </div>
  </section>

  <!-- DONASI TIER SECTION -->
  <section id="donasi" class="py-20 px-6 geo-bg">
    <div class="max-w-3xl mx-auto">
      <div class="reveal">
        <span class="inline-block bg-gold-100 border border-gold-500/30 text-gold-500 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Cara Berpartisipasi
        </span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-ink mb-4 leading-tight">
          Pilih Cara Anda<br>Bersedekah
        </h2>
        <p class="text-ink-muted leading-relaxed">
          Tidak ada nominal yang terlalu kecil di sisi Allah. Pilih yang paling Allah lapangkan untuk Anda hari ini.
        </p>
      </div>

      <div class="reveal grid grid-cols-1 gap-4 my-9">
        {institution.tiers.map((tier) => (
          <div class={`bg-white border-2 rounded-2xl p-7 flex items-start gap-5 hover:border-emerald-600 transition-all duration-300 cursor-pointer ${tier.featured ? 'border-gold-500 bg-gold-100' : 'border-emerald-600/10'}`}>
            <div class={`w-14 h-14 rounded-xl flex items-center justify-center font-serif font-bold text-xl flex-shrink-0 ${tier.featured ? 'bg-gold-500 text-white' : 'bg-emerald-100 text-emerald-600'}`}>
              {tier.number}
            </div>
            <div class="flex-1">
              <span class="text-2xl font-extrabold text-emerald-600 block mb-1">{tier.amount}</span>
              <div class="font-bold text-ink mb-1">{tier.label}</div>
              <p class="text-sm text-ink-muted leading-relaxed">{tier.desc}</p>
            </div>
            {tier.badge && (
              <span class="bg-gold-500 text-white text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded self-start mt-1">
                {tier.badge}
              </span>
            )}
          </div>
        ))}
      </div>

      <!-- WA Button -->
      <a href={institution.waLink} class="reveal block bg-wa text-white font-bold text-base px-8 py-4 rounded-xl text-center shadow-lg shadow-wa/30 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-wa/40 transition-all duration-300 mt-8">
        {institution.waText}
      </a>

      <div class="reveal text-center text-sm text-ink-faint -mt-2">
        Klik tombol di atas → chat otomatis terbuka → konfirmasi nominal & nama → selesai.
      </div>
    </div>
  </section>

  <!-- CARA DONASI SECTION -->
  <section class="bg-white border-t border-emerald-600/10 py-20 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="reveal">
        <span class="inline-block bg-gold-100 border border-gold-500/30 text-gold-500 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded mb-4">
          Detail Transfer
        </span>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-ink mb-4 leading-tight">
          Cara Mentransfer Dana
        </h2>
      </div>

      <div class="reveal grid grid-cols-1 md:grid-cols-2 gap-5 my-9">
        <div class="border border-emerald-600/10 rounded-2xl p-7 text-center">
          <span class="text-4xl mb-3 block">🏦</span>
          <div class="font-bold text-ink mb-2">Transfer Bank</div>
          <div class="text-sm text-ink-muted leading-relaxed">
            Bank: <strong class="text-emerald-600 font-bold">{institution.bank}</strong><br>
            No. Rekening: <strong class="text-emerald-600 font-bold">{institution.accountNumber}</strong><br>
            A/N: <strong class="text-emerald-600 font-bold">{institution.accountName}</strong>
          </div>
        </div>

        <div class="border border-emerald-600/10 rounded-2xl p-7 text-center">
          <span class="text-4xl mb-3 block">💬</span>
          <div class="font-bold text-ink mb-2">Konfirmasi Wajib</div>
          <div class="text-sm text-ink-muted leading-relaxed">
            Setelah transfer, kirim bukti ke WhatsApp admin dengan format:<br>
            <strong class="text-emerald-600 font-bold">NAMA — NOMINAL — PROGRAM</strong>
          </div>
        </div>
      </div>

      <div class="reveal bg-emerald-100 border border-emerald-600/10 rounded-xl p-6 text-sm text-emerald-600 leading-relaxed">
