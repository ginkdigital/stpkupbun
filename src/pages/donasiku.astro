---
import BaseLayout from '../layouts/BaseLayout.astro';

// JSON-LD Schema Data
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "EducationalOrganization",
      "name": "STP Khoiru Ummah Pangkalan Bun",
      "alternateName": "Sekolah Islam Tahfizh Plus Khoiru Ummah Pangkalan Bun",
      "url": "https://stpkupbun.pages.dev",
      "description": "Sekolah tahfidz terpadu TK hingga SMA di Pangkalan Bun, Kotawaringin Barat, Kalimantan Tengah. Bagian dari jaringan 80 sekolah Khoiru Ummah di 16 provinsi Indonesia.",
      "foundingDate": "2013",
      "legalName": "Yayasan Khoiru Ummah Pembangun Peradaban",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Jl. Samari 2, GG. Barokah RT.25, Kel. Madurejo",
        "addressLocality": "Pangkalan Bun",
        "addressRegion": "Kotawaringin Barat",
        "addressCountry": "ID",
        "postalCode": "74112"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": "-2.6833", "longitude": "111.6167" },
      "areaServed": { "@type": "City", "name": "Pangkalan Bun" },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Admissions",
        "url": "https://klikaja.app/tanyakupbun",
        "availableLanguage": "Indonesian"
      },
      "sameAs": [
        "https://khoiruummah.id",
        "https://linktr.ee/stpkupbun",
        "https://instagram.com/khoiruummahpbun_sd"
      ]
    },
    {
      "@type": "DonateAction",
      "name": "DonasiKU — 3 Pintu Amal Jariyah STPKU Pangkalan Bun",
      "description": "Program donasi resmi STP Khoiru Ummah Pangkalan Bun untuk program IQC dan HIT.",
      "url": "https://stpkupbun.pages.dev/donasiku",
      "recipient": { "@type": "EducationalOrganization", "name": "STP Khoiru Ummah Pangkalan Bun" },
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "7500000",
        "priceCurrency": "IDR",
        "description": "Biaya per peserta program IQC dan HIT"
      }
    }
  ]
};

// Data
const institution = {
  name: 'STP Khoiru Ummah Pangkalan Bun',
  target: 'Rp 195 Jt',
  iqcPercent: 33,
  bank: 'Bank Syariah Indonesia (BSI)',
  accountNumber: '7148055488',
  accountName: 'Megawati Apriani',
  waLink: 'https://wa.me/6281234567890?text=Assalamu%27alaikum.%20Saya%20ingin%20berpartisipasi%20dalam%20DonasiKU%20STPKU%20Pangkalan%20Bun.',
  stats: { tahun: '8', santo: '51', asatidz: '11' },
};
---

<BaseLayout
  title="DonasiKU — STPKU Pangkalan Bun | IQC & HIT 2026"
  description="51 santo penghafal Al-Qur'an di Kalimantan Tengah siap berlomba. Bantu mereka berangkat melalui Sedekah Jariyah Anda."
>
  <!-- JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- HERO -->
  <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16 text-center islamic-pattern">
    <!-- Logo -->
    <div class="w-20 h-20 bg-emerald-600 rounded-2xl flex items-center justify-center text-gold-500 font-serif text-3xl font-bold mb-8 animate-fade-up" style="animation-delay: 0.1s;">
      KU
    </div>

    <!-- Arabic -->
    <p class="font-serif text-lg md:text-xl text-gold-500 tracking-widest mb-6 opacity-80 animate-fade-up" style="animation-delay: 0.2s;">
      بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيْمِ
    </p>

    <!-- Headline -->
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white mb-6 animate-fade-up" style="animation-delay: 0.3s;">
      <span class="text-gold-500">51 Santo</span> Penghafal<br>
      Al-Qur'an di Kalimantan<br>
      <span class="text-emerald-500">Menunggu Tangan Anda</span>
    </h1>

    <!-- Sub -->
    <p class="text-white/60 text-lg max-w-lg mx-auto mb-8 leading-relaxed animate-fade-up" style="animation-delay: 0.4s;">
      Mereka sudah hafal. Mereka sudah siap berlomba.<br>
      Yang belum tersedia hanya dana untuk memberangkatkan mereka.
    </p>

    <!-- Stats -->
    <div class="flex gap-8 md:gap-12 mb-10 animate-fade-up" style="animation-delay: 0.5s;">
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-gold-500">{institution.target}</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Target</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-emerald-500">{institution.iqcPercent}%</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Terkumpul</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-red-progress">±Rp 130 Jt</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Kurang</span>
      </div>
    </div>

    <!-- CTA -->
    <a href="#donasi" class="bg-emerald-600 text-white font-bold text-lg px-8 py-4 rounded-xl hover:bg-emerald-500 transition-colors animate-fade-up" style="animation-delay: 0.6s;">
      💚 Berpartisipasi Sekarang
    </a>
  </section>

  <!-- SEKOLAH -->
  <section class="section-light py-16 px-6">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-ink mb-4 reveal">
        SD Tahfizh Plus Khoiru Ummah
      </h2>
      <p class="text-ink-muted leading-relaxed mb-8 reveal">
        Bagian dari jaringan nasional Khoiru Ummah — hadir di Kotawaringin Barat, Kalimantan Tengah sejak 2018. Santo dibentuk karakternya, dibangun akidahnya, dan dilatih menghafalkan Al-Qur'an.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-3 mb-8 reveal">
        <div class="p-4 bg-ink rounded-xl text-center">
          <span class="block font-serif text-2xl font-bold text-gold-500">{institution.stats.tahun}</span>
          <span class="text-xs text-white/60">Tahun</span>
        </div>
        <div class="p-4 bg-ink rounded-xl text-center">
          <span class="block font-serif text-2xl font-bold text-gold-500">{institution.stats.santo}</span>
          <span class="text-xs text-white/60">Santri</span>
        </div>
        <div class="p-4 bg-ink rounded-xl text-center">
          <span class="block font-serif text-2xl font-bold text-gold-500">{institution.stats.asatidz}</span>
          <span class="text-xs text-white/60">Asatidz</span>
        </div>
      </div>

      <p class="text-ink-muted reveal">
        Di bawah kepemimpinan <strong class="text-ink">Ustadz Mukhlis Syuaib, S.Pd</strong>
      </p>
    </div>
  </section>

  <!-- PROGRAM -->
  <section class="bg-ink py-16 px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-8 reveal">
        Dua Program Berprestasi
      </h2>

      <div class="grid grid-cols-2 gap-4">
        <div class="bg-white/5 border border-white/10 rounded-xl p-5 reveal">
          <div class="text-3xl mb-3">🏆</div>
          <h3 class="text-lg font-bold text-gold-500 mb-1">IQC</h3>
          <p class="text-xs text-white/50 mb-2">Islamic Quiz Competition<br>Yogyakarta, 31 Aug - 4 Sep 2026</p>
          <p class="text-sm text-white/40">Rp 7.500.000/peserta</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-xl p-5 reveal">
          <div class="text-3xl mb-3">📖</div>
          <h3 class="text-lg font-bold text-gold-500 mb-1">HIT</h3>
          <p class="text-xs text-white/50 mb-2">Historical Islamic Trip<br>Malaysia, 8-13 Jan 2027</p>
          <p class="text-sm text-white/40">Rp 7.500.000/peserta</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROGRESS -->
  <section class="bg-emerald-600 py-16 px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-8 reveal">
        Progress Donasi
      </h2>

      <!-- IQC Progress -->
      <div class="progress-card bg-white/10 border border-white/10 rounded-xl p-6 mb-4 reveal">
        <div class="flex justify-between items-center mb-4">
          <span class="font-bold text-white">🏆 IQC</span>
          <span class="font-serif text-2xl font-bold text-gold-500">{institution.iqcPercent}%</span>
        </div>
        <div class="bg-white/20 rounded-full h-2 mb-3">
          <div class="progress-bar-fill h-full rounded-full bg-gold-500" style="width: {institution.iqcPercent}%"></div>
        </div>
        <div class="flex justify-between text-xs text-white/60">
          <span>Rp 64.350.000 terkumpul</span>
          <span>Rp 195.000.000 target</span>
        </div>
      </div>

      <!-- Note -->
      <p class="text-center text-sm text-white/60 reveal">
        15 santo × Rp 7.500.000 = Rp 112.500.000 untuk pemberangkatan penuh
      </p>
    </div>
  </section>

  <!-- DONASI TIERS -->
  <section id="donasi" class="bg-ink py-16 px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-8 reveal">
        Pilih Cara Bersedekah
      </h2>

      <!-- Tier 1 -->
      <div class="bg-gold-500/10 border-2 border-gold-500 rounded-xl p-6 mb-4 reveal">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-gold-500 rounded-lg flex items-center justify-center text-xl">⭐</div>
          <div>
            <span class="text-xl font-bold text-gold-500">Rp 7.500.000</span>
            <span class="block text-xs text-white/60">Sponsor Penuh — 1 Santo</span>
          </div>
        </div>
        <p class="text-sm text-white/60 mb-4">Tanggung seluruh biaya satu santo. Satu nama Anda, satu santo berangkat.</p>
        <span class="inline-block bg-gold-500 text-ink text-xs font-bold px-3 py-1 rounded">Paling Berdampak</span>
      </div>

      <!-- Tier 2 -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-6 mb-4 reveal">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-emerald-600/30 rounded-lg flex items-center justify-center text-lg font-bold text-emerald-500">2</div>
          <div>
            <span class="text-lg font-bold text-white">Rp 500.000 – 5.000.000</span>
            <span class="block text-xs text-white/60">Sponsor Parsial</span>
          </div>
        </div>
        <p class="text-sm text-white/60">Bergabung dengan donatur lain dalam pool kolektif.</p>
      </div>

      <!-- Tier 3 -->
      <div class="bg-white/5 border border-white/10 rounded-xl p-6 mb-8 reveal">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-12 h-12 bg-emerald-600/30 rounded-lg flex items-center justify-center text-lg font-bold text-emerald-500">3</div>
          <div>
            <span class="text-lg font-bold text-white">Donasi Bebas</span>
            <span class="block text-xs text-white/60">Berapapun yang Allah Lapangkan</span>
          </div>
        </div>
        <p class="text-sm text-white/60">Tidak ada minimum. Yang penting niatnya bersih.</p>
      </div>

      <!-- WA Button -->
      <a href={institution.waLink} class="block bg-wa text-white font-bold text-lg py-4 rounded-xl text-center hover:opacity-90 transition-opacity reveal">
        💬 Konfirmasi via WhatsApp
      </a>
    </div>
  </section>

  <!-- TRANSFER -->
  <section class="section-light py-16 px-6">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-ink mb-8 reveal">Transfer Dana</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8 reveal">
        <div class="bg-ink text-white p-6 rounded-xl">
          <div class="text-3xl mb-3">🏦</div>
          <h3 class="font-bold mb-2">Bank</h3>
          <p class="text-sm text-white/60">
            {institution.bank}<br>
            {institution.accountNumber}<br>
            A/N: {institution.accountName}
          </p>
        </div>
        <div class="bg-emerald-100 p-6 rounded-xl">
          <div class="text-3xl mb-3">💬</div>
          <h3 class="font-bold text-ink mb-2">Konfirmasi</h3>
          <p class="text-sm text-ink-muted">
            Setelah transfer, kirim bukti ke WhatsApp dengan format:<br>
            <strong class="text-emerald-600">NAMA — NOMINAL — PROGRAM</strong>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CLOSING -->
  <section class="bg-ink py-16 px-6">
    <div class="max-w-xl mx-auto text-center">
      <p class="font-serif text-xl md:text-2xl text-gold-500 leading-relaxed mb-4 reveal" dir="rtl">
        "Barangsiapa yang menempuh suatu jalan untuk mencari ilmu, maka Allah akan memudahkan baginya jalan menuju surga."
      </p>
      <cite class="text-sm text-white/40 reveal">— HR. Muslim</cite>

      <div class="mt-8 reveal">
        <a href={institution.waLink} class="inline-block bg-gold-500 text-ink font-bold px-8 py-4 rounded-xl hover:bg-gold-300 transition-colors">
          💛 Ya, Saya Ingin Menanam Benih Ini
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
