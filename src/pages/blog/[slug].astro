---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
>
  <!-- Article -->
  <article class="min-h-screen pt-24 pb-16 px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Breadcrumb -->
      <div class="mb-8 animate-fade-up">
        <a href="/blog" class="text-sm text-white/40 hover:text-gold-500 transition-colors">
          ← Blog
        </a>
      </div>

      <!-- Header -->
      <header class="mb-10 animate-fade-up" style="animation-delay: 0.1s;">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.category && (
            <span class="text-xs font-semibold text-emerald-400 bg-emerald-600/20 px-2 py-0.5 rounded">
              {post.data.category}
            </span>
          )}
          {post.data.tags?.map(tag => (
            <span class="text-xs text-white/40 bg-white/10 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>

        <h1 class="font-serif text-3xl md:text-4xl font-bold text-white leading-tight mb-4">
          {post.data.title}
        </h1>

        <p class="text-lg text-white/60 leading-relaxed mb-4">
          {post.data.description}
        </p>

        <div class="flex items-center gap-3 text-sm text-white/40">
          <span>{post.data.author || 'STP Khoiru Ummah'}</span>
          {post.data.pubDate && (
            <>
              <span>·</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('id-ID', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
            </>
          )}
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-invert prose-emerald max-w-none animate-fade-up" style="animation-delay: 0.2s;">
        <Content />
      </div>

      <!-- Back -->
      <div class="mt-16 pt-8 border-t border-white/10 text-center">
        <a href="/blog" class="text-emerald-400 hover:text-gold-500 transition-colors">
          ← Kembali ke Blog
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #faf7f2;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #c9a84c;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    color: rgba(250, 247, 242, 0.8);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }
  .prose ul, .prose ol {
    color: rgba(250, 247, 242, 0.8);
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose strong {
    color: #c9a84c;
  }
  .prose em {
    color: rgba(250, 247, 242, 0.7);
    font-style: italic;
  }
  .prose blockquote {
    border-left: 3px solid #c9a84c;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: rgba(250, 247, 242, 0.7);
    font-style: italic;
  }
  .prose a {
    color: #2d8a61;
    text-decoration: underline;
  }
  .prose a:hover {
    color: #c9a84c;
  }
  .prose hr {
    border-color: rgba(255,255,255,0.1);
    margin: 2rem 0;
  }
</style>
