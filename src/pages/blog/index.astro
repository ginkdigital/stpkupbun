---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
  return dateB - dateA;
});
---

<BaseLayout
  title="Blog — STP Khoiru Ummah Pangkalan Bun"
  description="Artikel edukasi Islam, parenting, dan berita kegiatan STP Khoiru Ummah Pangkalan Bun."
>
  <!-- Hero -->
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-6 pt-24 pb-16 text-center islamic-pattern">
    <div class="w-16 h-16 bg-emerald-600 rounded-2xl flex items-center justify-center text-gold-500 font-serif text-2xl font-bold mb-6 animate-fade-up">
      KU
    </div>
    <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4 animate-fade-up" style="animation-delay: 0.1s;">
      Blog <span class="text-gold-500">STP Khoiru Ummah</span>
    </h1>
    <p class="text-white/60 max-w-lg animate-fade-up" style="animation-delay: 0.2s;">
      Artikel edukasi Islam, parenting, dan berita kegiatan sekolah di Kalimantan Tengah.
    </p>
  </section>

  <!-- Posts -->
  <section class="section-light py-16 px-6">
    <div class="max-w-3xl mx-auto">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-ink-muted text-lg mb-4">Artikel dalam persiapan.</p>
          <a href="/" class="text-emerald-600 font-semibold hover:underline">← Kembali ke Beranda</a>
        </div>
      ) : (
        <div class="space-y-6">
          {sortedPosts.map(post => (
            <article class="border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow reveal">
              <div class="flex items-center gap-2 mb-3">
                {post.data.category && (
                  <span class="text-xs font-semibold text-emerald-600 bg-emerald-100 px-2 py-0.5 rounded">
                    {post.data.category}
                  </span>
                )}
                {post.data.tags?.map(tag => (
                  <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
              <a href={`/blog/${post.id}`} class="block group">
                <h2 class="font-serif text-xl font-bold text-ink group-hover:text-emerald-600 transition-colors mb-2">
                  {post.data.title}
                </h2>
                <p class="text-ink-muted text-sm mb-3 line-clamp-2">
                  {post.data.description}
                </p>
                {post.data.pubDate && (
                  <time class="text-xs text-gray-400">
                    {new Date(post.data.pubDate).toLocaleDateString('id-ID', {
                      year: 'numeric', month: 'long', day: 'numeric'
                    })}
                  </time>
                )}
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
