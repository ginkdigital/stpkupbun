---
import BaseLayout from '../layouts/BaseLayout.astro';

// Data
const institution = {
  name: 'STP Khoiru Ummah Pangkalan Bun',
  stats: {
    tahun: '8',
    tahunLabel: 'Tahun di Kalteng',
    santri: '51',
    jalurSantri: 'Santri Aktif',
    asatidz: '11',
    asatidzLabel: 'Asatidz/ah',
  },
  wa: 'https://wa.me/6281234567890?text=Assalamu%27alaikum.%20Saya%20tertarik%20dengan%20STP%20Khoiru%20Ummah%20Pangkalan%20Bun',
};
---

<BaseLayout title="STP Khoiru Ummah Pangkalan Bun - Sekolah Penghafal Al-Qur'an">
  <!-- HERO - Bold, Signature -->
  <section class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-20 text-center islamic-pattern relative overflow-hidden">
    <!-- Logo Mark - Signature Element -->
    <div class="w-20 h-20 bg-emerald-600 rounded-2xl flex items-center justify-center text-gold-500 font-serif text-3xl font-bold mb-8 animate-fade-up" style="animation-delay: 0.1s;">
      KU
    </div>

    <!-- Arabic Ornament -->
    <p class="font-serif text-lg md:text-xl text-gold-500 tracking-widest mb-8 opacity-80 animate-fade-up" style="animation-delay: 0.2s;">
      بِسْمِ اللهِ الرَّحْمَنِ الرَّحِيْمِ
    </p>

    <!-- Headline - Boldness in ONE place -->
    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white mb-6 animate-fade-up" style="animation-delay: 0.3s;">
      <span class="text-gold-500">51 Santri</span><br>
      Penghafal Al-Qur'an<br>
      <span class="text-emerald-500">Menunggu Tangan Anda</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-white/60 text-lg max-w-lg mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay: 0.4s;">
      Mereka sudah hafal. Mereka sudah siap berlomba.<br>
      Yang belum tersedia hanya dana untuk memberangkatkan mereka.
    </p>

    <!-- Stats Bar -->
    <div class="flex gap-6 md:gap-12 mb-10 animate-fade-up" style="animation-delay: 0.5s;">
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-gold-500">Rp 195 Jt</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Target</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-emerald-500">33%</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Terkumpul</span>
      </div>
      <div class="text-center">
        <span class="block text-2xl md:text-3xl font-bold text-red-progress">±Rp 130 Jt</span>
        <span class="text-xs text-white/40 uppercase tracking-wider">Kurang</span>
      </div>
    </div>

    <!-- CTA - Single Bold Action -->
    <a
      href="/donasiku"
      class="inline-flex items-center gap-3 bg-emerald-600 text-white font-bold text-lg px-8 py-4 rounded-xl hover:bg-emerald-500 transition-all duration-300 animate-fade-up"
      style="animation-delay: 0.6s;"
    >
      💚 Berpartisipasi Sekarang
    </a>
  </section>

  <!-- SEKOLAH - Content Truth -->
  <section class="section-light py-20 px-6">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Section Title -->
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-ink mb-6 reveal">
        SD Tahfizh Plus Khoiru Ummah
      </h2>
      <p class="text-ink-muted leading-relaxed mb-10 reveal">
        Bagian dari jaringan nasional Khoiru Ummah — hadir di Kotawaringin Barat, Kalimantan Tengah sejak 2018. Di sini santo dibentuk karakternya, dibangun akidahnya, dan dilatih menghafalkan Al-Qur'an.
      </p>

      <!-- Stats Grid -->
      <div class="grid grid-cols-3 gap-4 mb-10 reveal">
        <div class="p-6 bg-ink rounded-xl text-center">
          <span class="block font-serif text-3xl font-bold text-gold-500">8</span>
          <span class="text-xs text-white/60">Tahun</span>
        </div>
        <div class="p-6 bg-ink rounded-xl text-center">
          <span class="block font-serif text-3xl font-bold text-gold-500">51</span>
          <span class="text-xs text-white/60">Santri</span>
        </div>
        <div class="p-6 bg-ink rounded-xl text-center">
          <span class="block font-serif text-3xl font-bold text-gold-500">11</span>
          <span class="text-xs text-white/60">Asatidz</span>
        </div>
      </div>

      <!-- Leadership -->
      <p class="text-ink-muted reveal">
        Di bawah kepemimpinan <strong class="text-ink">Ustadz Mukhlis Syuaib, S.Pd</strong> — mencetak generasi yang berpikir dengan aqidah.
      </p>
    </div>
  </section>

  <!-- PROGRAM - Visual Focus -->
  <section class="bg-ink py-20 px-6">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl font-bold text-white text-center mb-10 reveal">
        Dua Program Berprestasi
      </h2>

      <!-- Program Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- IQC -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors reveal">
          <div class="text-4xl mb-4">🏆</div>
          <h3 class="text-xl font-bold text-gold-500 mb-2">IQC</h3>
          <p class="text-sm text-white/60 mb-4">Islamic Quiz Competition<br>Yogyakarta, 31 Aug - 4 Sep 2026</p>
          <div class="text-sm text-white/40">
            Biaya: <strong class="text-emerald-500">Rp 7.500.000</strong>/peserta
          </div>
        </div>

        <!-- HIT -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors reveal">
          <div class="text-4xl mb-4">📖</div>
          <h3 class="text-xl font-bold text-gold-500 mb-2">HIT</h3>
          <p class="text-sm text-white/60 mb-4">Historical Islamic Trip<br>Malaysia, 8-13 Jan 2027</p>
          <div class="text-sm text-white/40">
            Biaya: <strong class="text-emerald-500">Rp 7.500.000</strong>/peserta
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE - Emotional Anchor -->
  <section class="bg-emerald-600 py-20 px-6">
    <div class="max-w-xl mx-auto text-center">
      <p class="font-serif text-2xl md:text-3xl text-white/90 leading-relaxed mb-6 reveal" dir="rtl">
        "Barangsiapa yang menempuh suatu jalan untuk mencari ilmu, maka Allah akan memudahkan baginya jalan menuju surga."
      </p>
      <cite class="text-sm text-gold-300 reveal">
        — HR. Muslim
      </cite>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-ink py-20 px-6">
    <div class="max-w-xl mx-auto text-center">
      <a
        href="/donasiku"
        class="inline-flex items-center gap-3 bg-wa text-white font-bold text-xl px-10 py-5 rounded-xl hover:opacity-90 transition-opacity reveal"
      >
        💬 Tanya via WhatsApp
      </a>
      <p class="text-white/40 text-sm mt-6 reveal">
        Klik untuk konfirmasi donasi Anda
      </p>
    </div>
  </section>
</BaseLayout>
